[user]
  useConfigOnly = true
	name = Alexander Katin
	email = aleksandr.katin@gmail.com
[github]
  user = lessthanzero
[credential]
{{ if eq .chezmoi.os "darwin" }}
  helper = osxkeychain
{{ else }}
  helper = cache
{{ end }}
[core]
  excludesfile = ~/.config/git/ignore
{{ if eq .chezmoi.os "darwin" }}
  editor = code --wait
{{ else }}
  editor = vim
{{ end }}
[push]
  default = simple
  followTags = true
[grep]
  lineNumber = true
[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true
[alias]
  hist = log --pretty=format:\"%h - %s [%an] (%cr)\" --graph --date=short
  lnm = log --no-merges --first-parent
  lnice = log --abbrev-commit --oneline --graph
  status = status -sb
  # Show the diff between the latest commit and the current state
  d = !"git diff-index --quiet HEAD -- || clear; git diff --patch-with-stat"
  save = stash save --include-untracked
